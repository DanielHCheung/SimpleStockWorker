---
// src/pages/index.astro
// Data is fetched at runtime from /data/report_data.json (generated by main.py)
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SimpleStockWorker — Strategy Monitor</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --bg:       #080b10;
      --surface:  #0e1318;
      --border:   #1e2730;
      --border2:  #2a3540;
      --text:     #c8d6e5;
      --muted:    #556070;
      --accent:   #f5a623;
      --green:    #00d68f;
      --red:      #ff4d6d;
      --blue:     #4da6ff;
      --mono:     'IBM Plex Mono', monospace;
      --sans:     'IBM Plex Sans', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 13px;
      min-height: 100vh;
    }

    /* ── TOP BAR ── */
    header {
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--surface);
    }

    .brand {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12em;
      color: var(--accent);
      text-transform: uppercase;
    }

    .header-right {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
    }

    #live-time { color: var(--text); }

    /* ── LAYOUT ── */
    main {
      padding: 20px 24px;
      max-width: 1400px;
      margin: 0 auto;
    }

    /* ── STAT CARDS ── */
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      margin-bottom: 20px;
    }

    .card {
      background: var(--surface);
      padding: 16px 18px;
      position: relative;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--border2);
    }

    .card.accent-green::before { background: var(--green); }
    .card.accent-red::before   { background: var(--red); }
    .card.accent-blue::before  { background: var(--blue); }
    .card.accent-amber::before { background: var(--accent); }

    .card-label {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .card-value {
      font-family: var(--mono);
      font-size: 22px;
      font-weight: 600;
      line-height: 1;
      color: var(--text);
    }

    .card-sub {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      margin-top: 6px;
    }

    .pos { color: var(--green); }
    .neg { color: var(--red); }

    /* ── CHART PANEL ── */
    .panel {
      background: var(--surface);
      border: 1px solid var(--border);
      margin-bottom: 20px;
    }

    .panel-header {
      border-bottom: 1px solid var(--border);
      padding: 10px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .panel-title {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .legend {
      display: flex;
      gap: 16px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
    }

    .legend-dot {
      width: 20px;
      height: 2px;
      border-radius: 1px;
    }

    .panel-body {
      padding: 16px 18px;
    }

    /* ── REGIME BAR ── */
    .regime-bar-wrap {
      display: flex;
      height: 20px;
      gap: 1px;
      margin-bottom: 4px;
    }

    .regime-segment {
      flex: 1;
      border-radius: 1px;
    }

    .regime-labels {
      display: flex;
      justify-content: space-between;
      font-family: var(--mono);
      font-size: 9px;
      color: var(--muted);
      margin-bottom: 12px;
    }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 12px 24px;
      display: flex;
      justify-content: space-between;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
    }

    /* ── LOADING ── */
    #loading {
      position: fixed;
      inset: 0;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.2em;
      color: var(--muted);
      z-index: 100;
    }

    .blink {
      animation: blink 1s step-end infinite;
    }

    @keyframes blink { 50% { opacity: 0; } }

    canvas { display: block; }
  </style>
</head>
<body>

<div id="loading">LOADING DATA<span class="blink">_</span></div>

<header>
  <span class="brand">SimpleStockWorker // Strategy Monitor</span>
  <span class="header-right">UTC <span id="live-time">--:--:--</span></span>
</header>

<main>
  <!-- STAT CARDS -->
  <div class="cards" id="cards">
    <div class="card accent-blue">
      <div class="card-label">Final NAV</div>
      <div class="card-value" id="stat-nav">—</div>
      <div class="card-sub" id="stat-start">Start: —</div>
    </div>
    <div class="card" id="card-pnl">
      <div class="card-label">P&amp;L</div>
      <div class="card-value" id="stat-pnl">—</div>
      <div class="card-sub" id="stat-pnl-pct">—</div>
    </div>
    <div class="card accent-amber">
      <div class="card-label">Trading Days</div>
      <div class="card-value" id="stat-days">—</div>
      <div class="card-sub" id="stat-period">Period</div>
    </div>
    <div class="card">
      <div class="card-label">Current Regime</div>
      <div class="card-value" id="stat-regime">—</div>
      <div class="card-sub">Market State</div>
    </div>
    <div class="card">
      <div class="card-label">vs QQQ</div>
      <div class="card-value" id="stat-vs-qqq">—</div>
      <div class="card-sub">Alpha (normalised)</div>
    </div>
  </div>

  <!-- REGIME TIMELINE -->
  <div class="panel">
    <div class="panel-header">
      <span class="panel-title">Regime Timeline</span>
      <div class="legend">
        <div class="legend-item"><div class="legend-dot" style="background:var(--green)"></div>Regime A</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--red)"></div>Regime B</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--border2)"></div>Neutral</div>
      </div>
    </div>
    <div class="panel-body">
      <div class="regime-bar-wrap" id="regime-bar"></div>
      <div class="regime-labels">
        <span id="regime-start">—</span>
        <span id="regime-end">—</span>
      </div>
    </div>
  </div>

  <!-- NAV CHART -->
  <div class="panel">
    <div class="panel-header">
      <span class="panel-title">NAV vs QQQ — Normalised to 100</span>
      <div class="legend">
        <div class="legend-item"><div class="legend-dot" style="background:var(--blue)"></div>Strategy</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--muted); border-top: 1px dashed var(--muted); height:0"></div>QQQ</div>
      </div>
    </div>
    <div class="panel-body">
      <canvas id="nav-chart" height="75"></canvas>
    </div>
  </div>
</main>

<footer>
  <span>AUTO-UPDATED DAILY VIA GITHUB ACTIONS</span>
  <span id="data-ts">DATA AS OF —</span>
</footer>

<script>
  // Live clock
  function tick() {
    const now = new Date();
    document.getElementById('live-time').textContent =
      now.toUTCString().split(' ')[4];
  }
  tick();
  setInterval(tick, 1000);

  // Load data
  fetch('./data/report_data.json')
    .then(r => r.json())
    .then(data => {
      document.getElementById('loading').style.display = 'none';
      render(data);
    })
    .catch(() => {
      document.getElementById('loading').textContent = 'DATA UNAVAILABLE';
    });

  function fmt(n) {
    return n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function render(data) {
    const { dates, nav, regimes, qqq } = data;

    // ── STATS ──
    const startNav = nav[0], endNav = nav[nav.length - 1];
    const pnl = endNav - startNav;
    const pnlPct = (pnl / startNav) * 100;

    const startQqq = qqq[0], endQqq = qqq[qqq.length - 1];
    const qqqReturn = ((endQqq - startQqq) / startQqq) * 100;
    const alpha = pnlPct - qqqReturn;

    const currentRegime = [...regimes].reverse().find(r => r !== null) || '—';

    document.getElementById('stat-nav').textContent = '$' + fmt(endNav);
    document.getElementById('stat-start').textContent = 'Start: $' + fmt(startNav);

    const pnlEl = document.getElementById('stat-pnl');
    const pnlCard = document.getElementById('card-pnl');
    pnlEl.textContent = (pnl >= 0 ? '+$' : '-$') + fmt(Math.abs(pnl));
    pnlEl.className = 'card-value ' + (pnl >= 0 ? 'pos' : 'neg');
    pnlCard.classList.add(pnl >= 0 ? 'accent-green' : 'accent-red');
    document.getElementById('stat-pnl-pct').textContent =
      (pnlPct >= 0 ? '+' : '') + pnlPct.toFixed(2) + '%';

    document.getElementById('stat-days').textContent = dates.length;
    document.getElementById('stat-period').textContent =
      dates[0] + ' → ' + dates[dates.length - 1];

    document.getElementById('stat-regime').textContent = currentRegime;

    const alphaEl = document.getElementById('stat-vs-qqq');
    alphaEl.textContent = (alpha >= 0 ? '+' : '') + alpha.toFixed(2) + '%';
    alphaEl.className = 'card-value ' + (alpha >= 0 ? 'pos' : 'neg');

    // ── REGIME BAR ──
    const bar = document.getElementById('regime-bar');
    regimes.forEach(r => {
      const seg = document.createElement('div');
      seg.className = 'regime-segment';
      seg.style.background =
        r === 'A' ? 'var(--green)' :
        r === 'B' ? 'var(--red)' :
        'var(--border2)';
      seg.title = r || 'Neutral';
      bar.appendChild(seg);
    });
    document.getElementById('regime-start').textContent = dates[0];
    document.getElementById('regime-end').textContent = dates[dates.length - 1];

    // ── DATA TIMESTAMP ──
    document.getElementById('data-ts').textContent =
      'DATA AS OF ' + dates[dates.length - 1].toUpperCase();

    // ── CHART ──
    const norm = arr => arr.map(v => v / arr[0] * 100);
    const navN = norm(nav);
    const qqqN = norm(qqq);

    // Build regime background zones
    const regimePlugin = {
      id: 'regimeBg',
      beforeDraw(chart) {
        const { ctx, chartArea, scales } = chart;
        if (!chartArea) return;
        const xScale = scales.x;
        regimes.forEach((r, i) => {
          if (!r) return;
          const x0 = xScale.getPixelForValue(i - 0.5);
          const x1 = xScale.getPixelForValue(i + 0.5);
          ctx.save();
          ctx.fillStyle = r === 'A'
            ? 'rgba(0,214,143,0.06)'
            : 'rgba(255,77,109,0.06)';
          ctx.fillRect(
            Math.max(x0, chartArea.left), chartArea.top,
            Math.min(x1, chartArea.right) - Math.max(x0, chartArea.left),
            chartArea.height
          );
          ctx.restore();
        });
      }
    };

    new Chart(document.getElementById('nav-chart'), {
      type: 'line',
      plugins: [regimePlugin],
      data: {
        labels: dates,
        datasets: [
          {
            label: 'Strategy NAV',
            data: navN,
            borderColor: '#4da6ff',
            borderWidth: 2,
            pointRadius: 0,
            pointHoverRadius: 4,
            pointHoverBackgroundColor: '#4da6ff',
            tension: 0.2,
            fill: {
              target: 'origin',
              above: 'rgba(77,166,255,0.05)',
            }
          },
          {
            label: 'QQQ',
            data: qqqN,
            borderColor: '#556070',
            borderWidth: 1.5,
            borderDash: [4, 4],
            pointRadius: 0,
            pointHoverRadius: 3,
            tension: 0.2,
          }
        ]
      },
      options: {
        responsive: true,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#0e1318',
            borderColor: '#1e2730',
            borderWidth: 1,
            titleColor: '#556070',
            bodyColor: '#c8d6e5',
            titleFont: { family: 'IBM Plex Mono', size: 10 },
            bodyFont: { family: 'IBM Plex Mono', size: 11 },
            padding: 10,
            callbacks: {
              title: items => items[0].label,
              label: ctx => {
                const regime = regimes[ctx.dataIndex];
                const suffix = regime ? ` [${regime}]` : '';
                return ` ${ctx.dataset.label}: ${ctx.parsed.y.toFixed(3)}${ctx.datasetIndex === 0 ? suffix : ''}`;
              }
            }
          }
        },
        scales: {
          x: {
            ticks: {
              color: '#556070',
              font: { family: 'IBM Plex Mono', size: 9 },
              maxTicksLimit: 10,
              maxRotation: 0,
            },
            grid: { color: '#1e2730' }
          },
          y: {
            ticks: {
              color: '#556070',
              font: { family: 'IBM Plex Mono', size: 9 },
              callback: v => v.toFixed(1)
            },
            grid: { color: '#1e2730' }
          }
        }
      }
    });
  }
</script>

</body>
</html>
